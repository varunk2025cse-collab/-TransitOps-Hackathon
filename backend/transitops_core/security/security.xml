<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record id="module_category_transitops" model="ir.module.category">
            <field name="name">TransitOps</field>
            <field name="description">Helps you manage your fleet operations.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Driver Group -->
        <record id="group_transitops_driver" model="res.groups">
            <field name="name">Driver</field>
            <field name="category_id" ref="module_category_transitops"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Field staff with limited access to trips and fuel logging.</field>
        </record>

        <!-- Fleet Manager Group -->
        <record id="group_transitops_manager" model="res.groups">
            <field name="name">Fleet Manager</field>
            <field name="category_id" ref="module_category_transitops"/>
            <field name="implied_ids" eval="[(4, ref('group_transitops_driver'))]"/>
            <field name="comment">Full access to vehicles, drivers, trips, and reports.</field>
        </record>
    </data>
</odoo>
